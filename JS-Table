[CSS]

table.style-tbl{
  border-collapse: collapse;
  margin-bottom: 40px;
}
.style-tbl th,.style-tbl td{
  border: 1px solid #000;
  padding: 5px;
  vertical-align: top;
}

.style-tbl td{ text-align: left; }
.style-tbl tr:nth-child(2n+2){ background: rgb(228, 238, 250); }
.style-tbl th{ background: rgb(238, 238, 238); }
