[SCSS]

$blue: #1a3c5a;
$green: #7ec134;
body{
  font-family: 'Montserrat', sans-serif;
  color: $blue;
  background: #00203c;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  h1{
    margin-bottom: 5vh;
        color: #ffffff36;
  }
  #password-app{
    height: fit-content;
    padding: 40px 25px;
    border-radius: 20px;
    box-shadow: 0px 7px 15px #b5b4b480;
    transition: all .4s linear;
    background: #fff;
    .input-field{
      display: flex;
      flex-direction: column;
      margin-bottom: 20px;
      animation: appear .5s;
      label{
        font-size: 20px;
        font-weight: 800;
        margin-bottom: 10px;
      }
      input{
        border-radius: 10px;
        border: 1px solid $blue;
        padding: 5px;
        transition: all .4s linear;
        margin-bottom: 10px;
        &::placeholder{
          color: #a9a9a9;
          font-size: 14px;
          font-weight: 100;
        }
        &:focus{
          outline: none;
          box-shadow: 0px 7px 15px #b5b4b450;
        }
      }
    }

    #requirements{
      padding: 0;
      list-style: none;
      li{
        font-size: 18px;
        margin-bottom: 7px;
        font-weight: 600;
        transition: all .4s linear;
        i{
          margin-right: 10px;
          transition: all .2s ease-in-out;
          &.fas{
            color: $green;
            transform: scale(1.3);
          }
        }
      }
    } 
    p{
      font-weight: 800;
    }
  }
}
@keyframes appear {
  0% {opacity: 0;}
  100% {opacity: 1;}
}

// Structure
$icon-base-size: 20px;
.success-icon {
  display: inline-block;
  width: 8em;
  height: 8em;
  font-size: $icon-base-size;
  border-radius: 50%;
  border: 4px solid lighten($green, 20%);
  background-color: #fff;
  position: relative;
  overflow: hidden;
  transform-origin: center;
  animation: showSuccess 180ms ease-in-out;
  transform: scale(1);
}

// Animated Check Mark & Cross by @elevaunt
svg {
  width: 100px;
  display: block;
  margin: 40px auto 0;
}

.path {
  stroke-dasharray: 1000;
  stroke-dashoffset: 0;
  &.circle {
    -webkit-animation: dash .9s ease-in-out;
    animation: dash .9s ease-in-out;
  }
  &.check {
    stroke-dashoffset: -100;
    -webkit-animation: dash-check .9s .35s ease-in-out forwards;
    animation: dash-check .9s .35s ease-in-out forwards;
  }
}

@-webkit-keyframes dash {
  0% {
    stroke-dashoffset: 1000;
  }
  100% {
    stroke-dashoffset: 0;
  }
}

@-webkit-keyframes dash-check {
  0% {
    stroke-dashoffset: -100;
  }
  100% {
    stroke-dashoffset: 900;
  }
}

.fa-instagram{
  position: absolute;
  color: $blue;
  top: 3%;
  right: 2%;
  font-size: 38px;
}

.fa-instagram:hover{
  font-size: 42px;
  color: $green;
  transition: all .1s linear;
  cursor: pointer;
}
